# Database (PostgreSQL in production)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# VAPI AI
VAPI_API_KEY="your-vapi-api-key"
VAPI_WEBHOOK_SECRET="your-vapi-webhook-secret"

# Encryption key for Twilio/GHL credentials (32 bytes hex)
ENCRYPTION_KEY="your-64-character-hex-encryption-key"

# GoHighLevel OAuth
GHL_CLIENT_ID=""
GHL_CLIENT_SECRET=""
GHL_REDIRECT_URI="https://app.swordaisolutions.com/api/oauth/callback"

# Google Calendar OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://app.swordaisolutions.com/api/calendar/oauth/google/callback"

# Server
PORT=5000
NODE_ENV=production
CLIENT_URL="https://app.swordaisolutions.com"
APP_URL="https://app.swordaisolutions.com"
WEBSITE_URL="https://swordaisolutions.com"
